rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - role-based access
    match /users/{userId} {
      // Users can read and write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Admins can read all user profiles
      allow read: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      // Only allow specific fields to be updated
      allow update: if request.auth != null && request.auth.uid == userId &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['title', 'location', 'theme', 'updatedAt']);
    }
    
    // Client view codes collection
    match /clientViewCodes/{code} {
      // Public read access for code validation
      allow read: if true;
      
      // Only admins can create, update, or delete codes
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      // Validate code structure
      allow create: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
        request.resource.data.keys().hasAll(['projectId', 'expiresAt', 'createdAt', 'createdBy']) &&
        request.resource.data.code is string &&
        request.resource.data.code.size() == 4 &&
        request.resource.data.projectId is string &&
        request.resource.data.expiresAt is timestamp &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.createdBy is string;
    }
    
    // Projects collection (for future use)
    match /projects/{projectId} {
      // Users can read projects they have access to
      allow read: if request.auth != null && (
        // Admins can read all projects
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        // Team members can read assigned projects
        resource.data.assignedUsers[request.auth.uid] == true ||
        // Project owners can read their projects
        resource.data.createdBy == request.auth.uid
      );
      
      // Only admins and project owners can write
      allow write: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        resource.data.createdBy == request.auth.uid
      );
    }
    
    // Tasks collection (for future use)
    match /tasks/{taskId} {
      // Users can read tasks they have access to
      allow read: if request.auth != null && (
        // Admins can read all tasks
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        // Assigned users can read their tasks
        resource.data.assignedTo == request.auth.uid ||
        // Project members can read tasks in their projects
        exists(/databases/$(database)/documents/projects/$(resource.data.projectId)) &&
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.assignedUsers[request.auth.uid] == true
      );
      
      // Only admins and assigned users can update tasks
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        resource.data.assignedTo == request.auth.uid
      );
      
      // Only admins can create and delete tasks
      allow create, delete: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Rate limiting for client view codes (basic implementation)
    match /rateLimits/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
} 